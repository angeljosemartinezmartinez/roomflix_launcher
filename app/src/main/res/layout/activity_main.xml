<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/ablMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/transparent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black"
            android:scaleType="fitXY" />

        <ImageView
            android:id="@+id/ver_tv"
            android:layout_width="60dp"
            android:layout_height="27dp"
            android:adjustViewBounds="true"
            android:scaleType="fitXY"
            android:background="@drawable/ver_tv"
            app:layout_constraintBottom_toTopOf="@+id/myVideo"
            app:layout_constraintEnd_toEndOf="@+id/myVideo"
            android:visibility="invisible"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/myVideo"
            android:layout_width="502dp"
            android:layout_height="282dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="94dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusRight="@id/btn7"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <VideoView
                android:id="@+id/video"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:visibility="invisible" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <ImageButton
            android:id="@+id/btn0"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/myVideo" />

        <ImageButton
            android:id="@+id/btn1"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="32dp"
            android:layout_marginTop="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btn0" />

        <ImageButton
            android:id="@+id/btn2"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="@+id/btn0"
            app:layout_constraintStart_toEndOf="@+id/btn0"
            app:layout_constraintTop_toTopOf="@+id/btn0" />


        <ImageButton
            android:id="@+id/btn3"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn1"
            app:layout_constraintTop_toTopOf="@+id/btn1"
            app:layout_constraintVertical_bias="0.0" />

        <ImageButton
            android:id="@+id/btn4"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="@+id/btn2"
            app:layout_constraintStart_toEndOf="@+id/btn2"
            app:layout_constraintTop_toTopOf="@+id/btn2" />

        <ImageButton
            android:id="@+id/btn5"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn3"
            app:layout_constraintTop_toTopOf="@+id/btn3"
            app:layout_constraintVertical_bias="0.0" />

        <ImageButton
            android:id="@+id/btn6"
            android:layout_width="70dp"
            android:layout_height="282dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/btn6"
            app:layout_constraintBottom_toBottomOf="@id/btn5"
            app:layout_constraintStart_toEndOf="@+id/btn4"
            app:layout_constraintTop_toBottomOf="@+id/myVideo" />

        <ImageButton
            android:id="@+id/btn7"
            android:layout_width="282dp"
            android:layout_height="282dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="94dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintStart_toEndOf="@+id/myVideo"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn8"
            android:layout_width="282dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            app:layout_constraintStart_toEndOf="@+id/btn6"
            app:layout_constraintTop_toTopOf="@+id/btn6" />

        <ImageButton
            android:id="@+id/btn9"
            android:layout_width="282dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:background="@color/transparent"
            android:nextFocusDown="@id/btn9"
            android:scaleType="centerInside"
            app:layout_constraintStart_toEndOf="@+id/btn6"
            app:layout_constraintTop_toBottomOf="@+id/btn8" />


        <ImageButton
            android:id="@+id/btn10"
            android:layout_width="282dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            app:layout_constraintStart_toEndOf="@+id/btn7"
            app:layout_constraintTop_toTopOf="@+id/btn7" />

        <ImageButton
            android:id="@+id/btn11"
            android:layout_width="282dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintStart_toEndOf="@+id/btn7"
            app:layout_constraintTop_toBottomOf="@id/btn10" />

        <ImageButton
            android:id="@+id/btn12"
            android:layout_width="282dp"
            android:layout_height="282dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/btn12"
            app:layout_constraintStart_toEndOf="@+id/btn8"
            app:layout_constraintTop_toBottomOf="@+id/btn11" />

        <ImageButton
            android:id="@+id/btn13"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="94dp"
            android:layout_marginBottom="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintBottom_toTopOf="@+id/btn14"
            app:layout_constraintStart_toEndOf="@+id/btn10"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn14"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintStart_toEndOf="@+id/btn11"
            app:layout_constraintTop_toTopOf="@+id/btn11" />

        <ImageButton
            android:id="@+id/btn15"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:scaleType="centerInside"
            app:layout_constraintStart_toEndOf="@+id/btn12"
            app:layout_constraintTop_toTopOf="@+id/btn12" />

        <ImageButton
            android:id="@+id/btn16"
            android:layout_width="138dp"
            android:layout_height="138dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="6dp"
            android:background="@color/transparent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:nextFocusDown="@id/btn16"
            android:scaleType="centerInside"
            app:layout_constraintStart_toEndOf="@+id/btn12"
            app:layout_constraintTop_toBottomOf="@+id/btn15" />

        <include
            android:id="@+id/help"
            layout="@layout/help_remote_control"
            android:focusable="false"
            android:focusableInTouchMode="false" />

        <include
            android:id="@+id/loader"
            layout="@layout/loader"
            android:focusable="false"
            android:focusableInTouchMode="false" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>