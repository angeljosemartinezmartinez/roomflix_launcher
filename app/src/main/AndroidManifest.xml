<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Permiso privilegiado (apps de sistema) para leer MAC real -->
    <uses-permission android:name="android.permission.LOCAL_MAC_ADDRESS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.SET_TIME_ZONE" />
    <uses-permission
        android:name="android.permission.WRITE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Permiso especial para Launchers: Permite ver TODAS las apps instaladas (API 30+) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" 
        tools:ignore="QueryAllPackagesPermission" />

    <!-- Android TV Features -->
    <uses-feature android:name="android.software.leanback" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

    <!-- Package Visibility Queries (API 30+): Permite detectar apps instaladas -->
    <queries>
        <!-- Intent para apps de TV (LEANBACK_LAUNCHER) - Permite ver cualquier app de TV -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
        </intent>
        <!-- YouTube: Múltiples variantes para máxima compatibilidad -->
        <package android:name="com.google.android.youtube.tv" />
        <package android:name="com.google.android.youtube" />
        <package android:name="com.google.android.tv.ytv" />
        <!-- Netflix: Múltiples variantes para máxima compatibilidad -->
        <package android:name="com.netflix.ninja" />
        <package android:name="com.netflix.mediaclient" />
        <!-- Amazon Prime Video: Múltiples variantes para máxima compatibilidad -->
        <package android:name="com.amazon.amazonvideo.livingroom" />
        <package android:name="com.amazon.avod.thirdpartyclient" />
        <!-- Otros servicios de streaming comunes -->
        <package android:name="com.hbo.hbonow" />
        <package android:name="com.disney.disneyplus" />
        <package android:name="com.spotify.tv.android" />
    </queries>

    <application
        android:name=".dragger.LauncherApplication"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:keepScreenOn="true"
        android:usesCleartextTraffic="true"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:banner="@drawable/tv_banner">
        <!-- SplashActivity: Pantalla de carga inicial -->
        <activity
            android:name=".views.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/AppTheme">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".views.activities.MainMenu"
            android:clearTaskOnLaunch="false"
            android:exported="false"
            android:launchMode="singleTask"
            tools:targetApi="n">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />

                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />

                <action android:name="android.intent.action.MANAGE_NETWORK_USAGE" />
                <action android:name="android.intent.action.ACTION_LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </activity>
        <activity android:launchMode="singleTask"
            android:name=".views.activities.MoreAppsActivity" />
        <activity
            android:name=".views.activities.InfoCardActivity"
            android:launchMode="singleTask" />
        <activity android:name=".views.activities.MoreAppsSubmenuActivity" />
        <activity android:name=".views.activities.CastTutorial" />
        <activity
            android:name=".views.activities.PlayerActivity"
            android:configChanges="screenSize|smallestScreenSize|screenLayout|orientation|layoutDirection"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:supportsPictureInPicture="true"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Roomflix.Player" />
        <activity
            android:name=".compose.epg.PlayerEPGScreen"
            android:configChanges="orientation|screenSize|layoutDirection"
            android:launchMode="singleInstance"
            android:screenOrientation="landscape"
            android:theme="@style/Theme.Roomflix.Player" />
        
        <!-- VpnService de GoBackend (WireGuard userspace embebido) -->
        <service
            android:name="com.wireguard.android.backend.GoBackend$VpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Actividad transparente para dialogo permiso VPN -->
        <activity
            android:name=".vpn.VpnPermissionActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false" />

        <!-- Device Admin Receiver (MDM / Kiosk): launcher fijo, lock task, pantalla siempre on -->
        <receiver
            android:name=".mdm.RoomflixDeviceAdminReceiver"
            android:description="@string/device_admin_description"
            android:exported="true"
            android:label="@string/device_admin_label"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_receiver" />
        </receiver>

        <!-- BootReceiver: Auto-lanzar la app al encender la TV -->
        <receiver
            android:name=".receivers.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.ACTION_LOCKED_BOOT_COMPLETED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>
    </application>

</manifest>